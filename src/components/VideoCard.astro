---
interface Props {
  id: string;
  title: string;
  url: string;
  channel: string;
  channel_url: string;
  upload_date: Date;
  duration_string: string;
  view_count: number;
  thumbnail: string;
  hasTranscript?: boolean;
}

const {
  id,
  title,
  url,
  channel,
  channel_url,
  upload_date,
  duration_string,
  view_count,
  thumbnail,
  hasTranscript = false,
} = Astro.props;

const formattedDate = upload_date.toLocaleDateString('en-GB', {
  month: 'long',
  year: 'numeric',
});

const formattedViews = view_count >= 1000000
  ? `${(view_count / 1000000).toFixed(1)}M`
  : view_count >= 1000
  ? `${(view_count / 1000).toFixed(0)}K`
  : view_count.toString();
---

<article class="card">
  <a href={url} target="_blank" rel="noopener noreferrer" class="card-link">
    <div class="thumbnail-wrap">
      <img
        src={thumbnail}
        alt={title}
        loading="lazy"
        onerror={`this.src='https://i.ytimg.com/vi/${id}/hqdefault.jpg'`}
      />
      <span class="duration">{duration_string}</span>
      {hasTranscript && <span class="transcript-badge">transcript</span>}
    </div>
    <div class="card-body">
      <h3 class="card-title">{title}</h3>
      <div class="card-meta">
        <a
          href={channel_url}
          target="_blank"
          rel="noopener noreferrer"
          class="channel"
          onclick="event.stopPropagation()"
        >{channel}</a>
        <span class="sep">·</span>
        <span>{formattedDate}</span>
        {view_count > 0 && (
          <>
            <span class="sep">·</span>
            <span>{formattedViews} views</span>
          </>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .card:hover {
    border-color: var(--border-hover);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
  }

  .card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .thumbnail-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg);
  }

  .thumbnail-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.2s ease;
  }

  .card:hover .thumbnail-wrap img {
    opacity: 0.85;
  }

  .duration {
    position: absolute;
    bottom: 8px;
    right: 8px;
    background: rgba(0, 0, 0, 0.85);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 2px 6px;
    border-radius: 2px;
    letter-spacing: 0.03em;
  }

  .transcript-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: var(--accent-dim);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 2px 6px;
    border-radius: 2px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .card-body {
    padding: 14px 16px 16px;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--text);
    margin-bottom: 8px;
  }

  .card-meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0 4px;
  }

  .channel {
    color: var(--accent);
    transition: color 0.15s;
  }

  .channel:hover {
    color: var(--text);
  }

  .sep {
    color: var(--text-dim);
  }
</style>
