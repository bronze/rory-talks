---
import { formatDate, formatViews } from '../lib/format';

interface Props {
  id: string;
  title: string;
  url: string;
  channel: string;
  channel_url: string;
  upload_date: Date;
  duration_string: string;
  view_count: number;
  thumbnail: string;
  hasTranscript?: boolean;
}

const {
  id,
  title,
  url,
  channel,
  channel_url,
  upload_date,
  duration_string,
  view_count,
  thumbnail,
  hasTranscript = false,
} = Astro.props;

const formattedDate = formatDate(upload_date);
const formattedViews = formatViews(view_count);
---

<article class="group rounded-sm border border-border bg-card transition-colors duration-200 hover:border-muted-foreground/40 hover:bg-secondary overflow-hidden">
  <a href={`/talks/${id}`} class="block">

    <!-- Thumbnail -->
    <div class="relative aspect-video overflow-hidden bg-background">
      <img
        src={thumbnail}
        alt={title}
        loading="lazy"
        class="w-full h-full object-cover transition-opacity duration-200 group-hover:opacity-85"
        onerror={`this.src='https://i.ytimg.com/vi/${id}/hqdefault.jpg'`}
      />
      <span class="absolute bottom-2 right-2 bg-black/85 text-foreground font-mono text-[0.7rem] px-1.5 py-0.5 rounded-sm tracking-wide">
        {duration_string}
      </span>
      {hasTranscript && (
        <span class="absolute top-2 left-2 bg-primary/20 text-primary font-mono text-[0.65rem] px-1.5 py-0.5 rounded-sm tracking-widest uppercase">
          transcript
        </span>
      )}
    </div>

    <!-- Body -->
    <div class="p-4">
      <h3 class="font-bold text-[0.95rem] leading-snug text-foreground mb-2">
        {title}
      </h3>
      <div class="flex flex-wrap items-center gap-x-1.5 gap-y-0.5 font-mono text-[0.7rem] text-muted-foreground">
        <a
          href={channel_url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary hover:text-foreground transition-colors"
          onclick="event.stopPropagation()"
        >{channel}</a>
        <span class="text-border">·</span>
        <span>{formattedDate}</span>
        {formattedViews && (
          <>
            <span class="text-border">·</span>
            <span>{formattedViews} views</span>
          </>
        )}
      </div>
    </div>
  </a>
</article>
