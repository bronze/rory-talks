---
import { Image } from 'astro:assets';
import { formatDate, formatViews } from '../lib/format';

interface Props {
  id: string;
  title: string;
  url: string;
  channel: string;
  channel_url: string;
  upload_date: Date;
  duration_string: string;
  view_count: number;
  thumbnail: string;

  topics?: string[];
}

const {
  id,
  title,
  url,
  channel,
  channel_url,
  upload_date,
  duration_string,
  view_count,
  thumbnail,

  topics = [],
} = Astro.props;

const TOPIC_LABELS: Record<string, string> = {
  'reframing': 'Reframing',
  'alchemy': 'Alchemy',
  'signalling': 'Signalling',
  'complexity': 'Complexity',
  'brand': 'Brand',
  'risk': 'Risk',
  'finance': 'Finance',
};

const formattedDate = formatDate(upload_date);
const formattedViews = formatViews(view_count);

const localThumbnails = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/thumbnails/*.jpg',
  { eager: true }
);
const localThumb = localThumbnails[`/src/assets/thumbnails/${id}.jpg`]?.default;
---

<article class="group relative rounded-sm border border-border bg-card transition-colors duration-200 hover:border-muted-foreground/40 hover:bg-secondary overflow-hidden cursor-pointer" data-topics={topics.join(',')}>

  <!-- Stretched link covering the whole card -->
  <a href={`/talks/${id}`} class="absolute inset-0 z-10" aria-label={title}></a>

  <!-- Thumbnail -->
  <div class="relative aspect-video overflow-hidden bg-background">
    {localThumb ? (
      <Image
        src={localThumb}
        alt={title}
        widths={[400, 800]}
        sizes="(max-width: 640px) 100vw, 400px"
        class="w-full h-full object-cover transition-opacity duration-200 group-hover:opacity-85"
      />
    ) : (
      <img
        src={thumbnail}
        alt={title}
        loading="lazy"
        class="w-full h-full object-cover transition-opacity duration-200 group-hover:opacity-85"
      />
    )}
    <span class="absolute bottom-2 right-2 bg-black/85 text-foreground font-mono text-xs px-1.5 py-0.5 rounded-sm tracking-wide">
      {duration_string}
    </span>

  </div>

  <!-- Body -->
  <div class="p-4">
    <h3 class="font-bold text-lg leading-snug text-foreground mb-2">
      {title}
    </h3>
    <div class="flex flex-wrap items-center gap-x-1.5 gap-y-0.5 font-mono text-sm text-muted-foreground">
      <a
        href={channel_url}
        target="_blank"
        rel="noopener noreferrer"
        class="relative z-20 text-primary hover:text-foreground transition-colors"
      >{channel}</a>
      <span class="text-border">·</span>
      <span>{formattedDate}</span>
      {formattedViews && (
        <>
          <span class="text-border">·</span>
          <span>{formattedViews} views</span>
        </>
      )}
    </div>
    {topics.length > 0 && (
      <div class="relative z-20 flex flex-wrap gap-1 mt-2.5">
        {topics.map(t => (
          <a
            href={`/topics/${t}`}
            class="font-mono text-xs tracking-wide px-1.5 py-0.5 rounded-sm border border-border text-muted-foreground hover:border-primary hover:text-primary transition-colors"
          >
            {TOPIC_LABELS[t] ?? t}
          </a>
        ))}
      </div>
    )}
  </div>
</article>
