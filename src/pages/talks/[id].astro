---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const videos = await getCollection('videos');
  return videos.map(video => ({
    params: { id: video.data.id },
    props: { video },
  }));
}

const { video } = Astro.props;
const { data } = video;

const PLAYLIST_ID = 'PLGxDladnEAZ1wNjUglLAnDR4nQDAhntKc';

const TOPIC_LABELS: Record<string, string> = {
  'reframing': 'Reframing',
  'alchemy': 'Alchemy',
  'signalling': 'Signalling',
  'complexity': 'Complexity',
  'brand': 'Brand',
  'risk': 'Risk',
  'finance': 'Finance',
};

const allTranscripts = await getCollection('transcripts');
const transcript = allTranscripts.find(t => t.data.id === data.id);

const allBooks = await getCollection('books');
const mentionedBooks = allBooks.filter(b => b.data.mentioned_in.includes(data.id));

const bookCovers = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/book-covers/*.jpg',
  { eager: true }
);

const { Content } = await render(video);

const formattedDate = data.upload_date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const formattedViews = data.view_count >= 1_000_000
  ? `${(data.view_count / 1_000_000).toFixed(1)}M`
  : data.view_count >= 1_000
  ? `${(data.view_count / 1_000).toFixed(0)}K`
  : data.view_count > 0 ? data.view_count.toString() : null;

// Parse takeaways from markdown body
const takeawaysMatch = video.body?.match(/## Key Takeaways\n\n((?:- .+\n?)+)/);
const takeaways = takeawaysMatch
  ? takeawaysMatch[1].split('\n').filter((l: string) => l.startsWith('- ')).map((l: string) => l.slice(2).trim())
  : [];
---

<Base title={`${data.title} — Rory Sutherland`} description={data.description}>
  <main class="max-w-4xl mx-auto px-6 pb-24 pt-10 sm:px-4">

    <!-- Video embed -->
    <div class="aspect-video w-full mb-8 rounded-sm overflow-hidden border border-border bg-background">
      <iframe
        src={`https://www.youtube.com/embed/${data.id}?${data.start_time ? `start=${data.start_time}&` : ''}list=${PLAYLIST_ID}`}
        title={data.title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        class="w-full h-full"
      ></iframe>
    </div>

    <!-- Meta -->
    <div class="mb-10">
      <h1 class="font-bold text-2xl leading-snug text-foreground mb-3 sm:text-xl">
        {data.title}
      </h1>
      {data.topics.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-4">
          {data.topics.map((t: string) => (
            <a
              href={`/topics/${t}`}
              class="font-mono text-[0.62rem] tracking-wide px-1.5 py-0.5 rounded-sm border border-border text-muted-foreground hover:border-primary hover:text-primary transition-colors"
            >
              {TOPIC_LABELS[t] ?? t}
            </a>
          ))}
        </div>
      )}
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-[0.72rem] text-muted-foreground">
        <a
          href={data.channel_url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary hover:text-foreground transition-colors"
        >{data.channel}</a>
        <span class="text-border">·</span>
        <span>{formattedDate}</span>
        <span class="text-border">·</span>
        <span>{data.duration_string}</span>
        {formattedViews && (
          <>
            <span class="text-border">·</span>
            <span>{formattedViews} views</span>
          </>
        )}
        <a
          href={`${data.url}&list=${PLAYLIST_ID}${data.start_time ? `&t=${data.start_time}s` : ''}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 px-2 py-0.5 rounded-sm bg-[#FF0000]/8 text-[#cc2200] border border-[#FF0000]/15 hover:bg-[#FF0000]/15 transition-colors"
        >watch on YouTube ↗</a>
      </div>
    </div>

    <!-- Key Takeaways -->
    {takeaways.length > 0 && (
      <div class="border-t border-border pt-10 mb-10">
        <p class="font-mono text-[0.7rem] tracking-[0.15em] uppercase text-primary mb-4">Key Takeaways</p>
        <ul class="space-y-3">
          {takeaways.map((t: string) => (
            <li class="flex gap-3 text-[0.95rem] text-muted-foreground leading-relaxed">
              <span class="text-primary mt-[0.35rem] shrink-0">—</span>
              <span>{t}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Books mentioned -->
    {mentionedBooks.length > 0 && (
      <div class="border-t border-border pt-10 mb-10">
        <p class="font-mono text-[0.7rem] tracking-[0.15em] uppercase text-primary mb-5">Books mentioned</p>
        <ul class="grid grid-cols-3 gap-3 lg:grid-cols-2 sm:grid-cols-1">
          {mentionedBooks.map(book => {
            const slug = book.id.replace(/\.md$/, '');
            const cover = bookCovers[`/src/assets/book-covers/${slug}.jpg`]?.default;
            return (
              <li>
                <a href={`/books#${slug}`} class="rounded-sm border border-border bg-secondary/30 p-4 flex gap-4 hover:bg-secondary/60 transition-colors h-full">
                  {cover && (
                    <Image
                      src={cover}
                      alt={`${book.data.title} cover`}
                      widths={[72, 144]}
                      sizes="72px"
                      class="w-[4.5rem] rounded-sm border border-border shadow-sm shrink-0 self-start"
                    />
                  )}
                  <div class="min-w-0">
                    <p class="font-bold text-[0.85rem] text-foreground leading-snug line-clamp-2">{book.data.title}</p>
                    <p class="font-mono text-[0.68rem] text-muted-foreground mt-0.5">{book.data.author}</p>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    )}

    <!-- Remaining content (Stories & Examples, Notes, etc.) -->
    <div class:list={['prose-rory', takeaways.length > 0 && 'hide-first-section']}>
      <Content />
    </div>

  </main>
</Base>

<style>
  /* Prose styles scoped to this page */
  .prose-rory :global(h2) {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--primary);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose-rory :global(h3) {
    font-size: 1rem;
    font-weight: 700;
    color: var(--foreground);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose-rory :global(p) {
    color: var(--muted-foreground);
    line-height: 1.75;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .prose-rory :global(ul),
  .prose-rory :global(ol) {
    color: var(--muted-foreground);
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    font-size: 0.95rem;
    line-height: 1.75;
  }

  .prose-rory :global(li) {
    margin-bottom: 0.35rem;
  }

  .prose-rory :global(li::marker) {
    color: var(--primary);
  }

  .prose-rory :global(a) {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose-rory :global(blockquote) {
    border-left: 2px solid var(--primary);
    padding-left: 1rem;
    margin-left: 0;
    color: var(--muted-foreground);
    font-style: italic;
  }

  .prose-rory :global(code) {
    font-family: 'DM Mono', monospace;
    font-size: 0.85em;
    background: var(--secondary);
    padding: 0.1em 0.4em;
    border-radius: 2px;
  }

  /* Hide empty placeholder sections */
  .prose-rory :global(p:has(+ ul:empty)),
  .prose-rory :global(ul:empty) {
    display: none;
  }

  /* Suppress Key Takeaways from <Content /> when rendered separately above */
  .hide-first-section :global(h2:first-child),
  .hide-first-section :global(h2:first-child + ul) {
    display: none;
  }
</style>
