---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import VideoCard from '../components/VideoCard.astro';
import { formatRuntime } from '../lib/format';

const allVideos = await getCollection('videos');
const allTranscripts = await getCollection('transcripts');
const transcriptIds = new Set(allTranscripts.map(t => t.data.id));

const TOPIC_LABELS: Record<string, string> = {
  'reframing': 'Reframing',
  'alchemy': 'Alchemy',
  'signalling': 'Signalling',
  'complexity': 'Complexity',
  'brand': 'Brand',
  'risk': 'Risk',
  'finance': 'Finance',
};

const TOPIC_DESCRIPTIONS: Record<string, string> = {
  'reframing': 'Changing context or perception to reveal hidden value',
  'alchemy': 'Irrational solutions that outperform rational ones',
  'signalling': 'Trust, costly signals, and why form matters as much as function',
  'complexity': 'Emergence, bottom-up thinking, and why mess is a feature',
  'brand': 'Advertising craft, brand equity, and what brands actually do',
  'risk': 'Variance vs expected value, uncertainty, and why playing safe is dangerous',
  'finance': 'When economic logic fails — pensions, investment, cost reduction',
};

// Topics ordered by talk count descending
const topicCounts = new Map<string, number>();
for (const v of allVideos) {
  for (const t of v.data.topics) topicCounts.set(t, (topicCounts.get(t) ?? 0) + 1);
}
const topics = [...topicCounts.entries()].sort((a, b) => b[1] - a[1]).map(([slug]) => slug);

// Most recent first
const videos = allVideos.sort(
  (a, b) => b.data.upload_date.getTime() - a.data.upload_date.getTime()
);

// Stats
const totalDuration = videos.reduce((sum, v) => sum + v.data.duration, 0);
const { hours: totalHours, mins: totalMins } = formatRuntime(totalDuration);
const years = videos.map(v => v.data.upload_date.getFullYear());
const earliestYear = Math.min(...years);
const latestYear = Math.max(...years);
---

<Base title="Rory Sutherland — Talks & Interviews">
  <main class="max-w-6xl mx-auto px-6 pb-20 sm:px-4">

    <!-- Header -->
    <header class="py-16 border-b border-border mb-14 sm:py-10">
      <p class="font-mono text-xs tracking-[0.15em] uppercase text-primary mb-3">
        curated archive
      </p>
      <h1 class="font-bold text-5xl tracking-tight leading-none text-foreground mb-2 sm:text-3xl">
        Rory Sutherland
      </h1>
      <p class="italic text-lg text-muted-foreground mb-6">
        Talks, interviews & lectures
      </p>
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-sm text-muted-foreground">
        <span>{videos.length} talks</span>
        <span class="text-border">·</span>
        <span>{totalHours}h {totalMins}m total</span>
        <span class="text-border">·</span>
        <span>{earliestYear}–{latestYear}</span>
        {transcriptIds.size > 0 && (
          <>
            <span class="text-border">·</span>
            <span>{transcriptIds.size} transcripts</span>
          </>
        )}
      </div>
    </header>

    <!-- Topic filter -->
    <div class="flex flex-wrap gap-2 mb-10" id="topic-filters">
      <button
        class="topic-btn font-mono text-sm px-3 py-1.5 rounded-sm border border-primary text-primary transition-colors cursor-pointer"
        data-topic="all"
      >All ({videos.length})</button>
      {topics.map(slug => (
        <div class="relative group/tip">
          <button
            class="topic-btn font-mono text-sm px-3 py-1.5 rounded-sm border border-border text-muted-foreground hover:border-primary hover:text-primary transition-colors cursor-pointer"
            data-topic={slug}
          >{TOPIC_LABELS[slug]} ({topicCounts.get(slug)})</button>
          <div class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-52 rounded-sm bg-popover border border-border px-2.5 py-1.5 font-mono text-xs text-muted-foreground leading-snug opacity-0 group-hover/tip:opacity-100 transition-opacity duration-150 z-10 text-center shadow-md">
            {TOPIC_DESCRIPTIONS[slug]}
          </div>
        </div>
      ))}
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3" id="video-grid">
      {videos.map(video => (
        <VideoCard
          id={video.data.id}
          title={video.data.title}
          url={video.data.url}
          channel={video.data.channel}
          channel_url={video.data.channel_url}
          upload_date={video.data.upload_date}
          duration_string={video.data.duration_string}
          view_count={video.data.view_count}
          thumbnail={video.data.thumbnail}
          hasTranscript={transcriptIds.has(video.data.id)}
          topics={video.data.topics}
        />
      ))}
    </div>

  </main>
</Base>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.topic-btn');
  const cards = document.querySelectorAll<HTMLElement>('#video-grid article');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const topic = btn.dataset.topic!;

      // Update button styles
      buttons.forEach(b => {
        const active = b.dataset.topic === topic;
        b.classList.toggle('border-primary', active);
        b.classList.toggle('text-primary', active);
        b.classList.toggle('border-border', !active);
        b.classList.toggle('text-muted-foreground', !active);
      });

      // Show/hide cards
      cards.forEach(card => {
        const cardTopics = card.dataset.topics?.split(',') ?? [];
        const visible = topic === 'all' || cardTopics.includes(topic);
        card.style.display = visible ? '' : 'none';
      });
    });
  });
</script>
