---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import VideoCard from '../components/VideoCard.astro';
import { formatRuntime } from '../lib/format';

const allVideos = await getCollection('videos');
const allTranscripts = await getCollection('transcripts');
const transcriptIds = new Set(allTranscripts.map(t => t.data.id));

// Most recent first
const videos = allVideos.sort(
  (a, b) => b.data.upload_date.getTime() - a.data.upload_date.getTime()
);

// Stats
const totalDuration = videos.reduce((sum, v) => sum + v.data.duration, 0);
const { hours: totalHours, mins: totalMins } = formatRuntime(totalDuration);
const years = videos.map(v => v.data.upload_date.getFullYear());
const earliestYear = Math.min(...years);
const latestYear = Math.max(...years);
---

<Base title="Rory Sutherland — Talks & Interviews">
  <main class="max-w-6xl mx-auto px-6 pb-20 sm:px-4">

    <!-- Header -->
    <header class="py-16 border-b border-border mb-14 sm:py-10">
      <p class="font-mono text-[0.7rem] tracking-[0.15em] uppercase text-primary mb-3">
        curated archive
      </p>
      <h1 class="font-bold text-5xl tracking-tight leading-none text-foreground mb-2 sm:text-3xl">
        Rory Sutherland
      </h1>
      <p class="italic text-lg text-muted-foreground mb-6">
        Talks, interviews & lectures
      </p>
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-[0.75rem] text-muted-foreground">
        <span>{videos.length} talks</span>
        <span class="text-border">·</span>
        <span>{totalHours}h {totalMins}m total</span>
        <span class="text-border">·</span>
        <span>{earliestYear}–{latestYear}</span>
        {transcriptIds.size > 0 && (
          <>
            <span class="text-border">·</span>
            <span>{transcriptIds.size} transcripts</span>
          </>
        )}
      </div>
    </header>

    <!-- Grid -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {videos.map(video => (
        <VideoCard
          id={video.data.id}
          title={video.data.title}
          url={video.data.url}
          channel={video.data.channel}
          channel_url={video.data.channel_url}
          upload_date={video.data.upload_date}
          duration_string={video.data.duration_string}
          view_count={video.data.view_count}
          thumbnail={video.data.thumbnail}
          hasTranscript={transcriptIds.has(video.data.id)}
        />
      ))}
    </div>

  </main>
</Base>
